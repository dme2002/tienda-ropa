---
import { Icon } from "astro-icon/components";

const categorias = [
    { name: "Inicio", href: "/" },
    {
        name: "Catálogo",
        href: "/categoria/computadoras",
    },
    {
        name: "Temporada",
        href: "/temporada",
    },
    {
        name: "Exportación",
        href: "/exportacion",
    },
];


const telefonoWhatsapp = "50497665442"; 
const mensajeWhatsapp = encodeURIComponent("Me gustaría cotizar una carga.");
const urlWhatsapp = `https://wa.me/${telefonoWhatsapp}?text=${mensajeWhatsapp}`;
---

<nav class="bg-primary text-primary-content shadow-sm relative z-40">
    <div class="max-w-7xl mx-auto flex justify-between items-center text-xs sm:text-sm font-medium h-10">
        
        <div class="flex sm:hidden w-full items-center justify-between h-full px-4">
            <button
                id="toggle-enlaces-movil"
                class="flex items-center gap-2 h-full px-2 hover:bg-white/10 transition-colors cursor-pointer"
            >
                <span>Categorías</span>
                <Icon
                    name="lucide:chevron-down"
                    id="icono-chevron"
                    class="w-4 h-4 transition-transform duration-300"
                />
            </button>

            <div class="flex h-full items-center">
                <a href="/contacto" class="flex items-center h-full px-2 hover:bg-white/10 transition-colors">Contacto</a>
            </div>
        </div>

        <div class="hidden sm:flex h-full items-center">
            {
                categorias.map((cat) => (
                    <a
                        href={cat.href}
                        class="flex items-center h-full px-4 hover:bg-white/10 text-white/90 hover:text-white transition-all cursor-pointer"
                    >
                        {cat.name}
                    </a>
                ))
            }
        </div>

        <div class="hidden sm:flex h-full items-center">
            <a href="/nosotros" class="flex items-center h-full px-4 hover:bg-white/10 text-white/90 hover:text-white transition-all cursor-pointer">Sobre Nosotros</a>
            <a href="/contacto" class="flex items-center h-full px-4 hover:bg-white/10 text-white/90 hover:text-white transition-all cursor-pointer">Contacto</a>
        </div>
    </div>

    <div
        id="menu-enlaces-movil"
        class="sm:hidden grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out bg-primary overflow-hidden brightness-95"
    >
        <div class="min-h-0 flex flex-col border-t border-white/10">
            {
                categorias.map((cat) => (
                    <a href={cat.href} class="py-3 px-6 hover:bg-white/10 border-b border-white/5 transition-colors uppercase text-[10px] tracking-wider font-bold">
                        {cat.name}
                    </a>
                ))
            }
            <a href="/nosotros" class="py-3 px-6 hover:bg-white/10 border-b border-white/5 transition-colors">Sobre Nosotros</a>
        </div>
    </div>
</nav>

<div class="contenedor-whatsapp">
    <a
        href={urlWhatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="boton-whatsapp grupo"
    >
        <span class="etiqueta-whatsapp">¡Cotizar Carga!</span>
        <div class="circulo-icono-whatsapp">
            <span class="efecto-pulso"></span>
            <Icon name="lucide:message-circle" class="w-8 h-8 relative z-10" />
        </div>
    </a>
</div>

<script>
    const configurarMenu = () => {
        const botonToggle = document.getElementById("toggle-enlaces-movil");
        const menu = document.getElementById("menu-enlaces-movil");
        const chevron = document.getElementById("icono-chevron");

        if (botonToggle && menu && chevron) {
            botonToggle.addEventListener("click", () => {
                const estaAbierto = menu.classList.contains("grid-rows-[1fr]");
                menu.classList.toggle("grid-rows-[1fr]", !estaAbierto);
                menu.classList.toggle("grid-rows-[0fr]", estaAbierto);
                chevron.classList.toggle("rotate-180", !estaAbierto);
            });
        }
    };

    configurarMenu();
    document.addEventListener("astro:after-swap", configurarMenu);
</script>

<style>
    
    .contenedor-whatsapp {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9999;
        pointer-events: none;
    }

    .boton-whatsapp {
        display: flex;
        align-items: center;
        text-decoration: none;
        pointer-events: auto;
    }

    .etiqueta-whatsapp {
        margin-right: 12px;
        background-color: white;
        color: #1f2937;
        padding: 8px 16px;
        border-radius: 8px;
        font-weight: 700;
        font-size: 14px;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        border: 1px solid #f3f4f6;
        opacity: 0;
        transform: translateX(10px);
        transition: all 0.3s ease;
    }

   
    @media (min-width: 640px) {
        .boton-whatsapp:hover .etiqueta-whatsapp {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .circulo-icono-whatsapp {
        background-color: #22c55e;
        color: white;
        padding: 16px;
        border-radius: 9999px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.2);
        position: relative;
        transition: transform 0.3s ease;
    }

    .boton-whatsapp:hover .circulo-icono-whatsapp {
        transform: scale(1.1);
        background-color: #16a34a;
    }

    .efecto-pulso {
        position: absolute;
        inset: 0;
        border-radius: 9999px;
        background-color: #22c55e;
        animation: pulso-anim 2s cubic-bezier(0, 0, 0.2, 1) infinite;
        opacity: 0.4;
    }

    @keyframes pulso-anim {
        75%, 100% {
            transform: scale(2);
            opacity: 0;
        }
    }

    
    @media (max-width: 639px) {
        .etiqueta-whatsapp {
            display: none;
        }
    }
</style>
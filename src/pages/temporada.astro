---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Producto de Temporada | Cacao Premium">
    <main class="bg-gray-50 min-h-screen">
        <section class="relative h-[400px] flex items-center justify-center text-white">
            <div class="absolute inset-0 z-0">
                <img 
                    src="https://images.unsplash.com/photo-1542691457-cbe4df041eb2?auto=format&fit=crop&w=1200&q=80" 
                    class="w-full h-full object-cover brightness-50"
                    alt="Cacao de temporada"
                />
            </div>
            <div class="relative z-10 text-center px-4">
                <span class="bg-green-600 text-white px-4 py-1 rounded-full text-sm font-bold uppercase tracking-widest">Edición Limitada</span>
                <h1 class="text-5xl md:text-6xl font-black mt-4 shadow-sm">Cacao Fino de Aroma</h1>
                <p class="text-xl mt-4 max-w-2xl mx-auto text-gray-200">Disponible únicamente durante los meses de cosecha de invierno. Calidad de exportación directa del productor.</p>
            </div>
        </section>

        <section class="max-w-6xl mx-auto py-16 px-4">
            <div class="grid md:grid-cols-2 gap-12 items-center">
                <div class="space-y-6">
                    <h2 class="text-3xl font-bold text-green-800">¿Por qué es especial esta cosecha?</h2>
                    <p class="text-gray-600 leading-relaxed">
                        Nuestro cacao de temporada es seleccionado a mano bajo estrictos controles de fermentación. Durante este periodo, los granos desarrollan notas sensoriales únicas a frutos rojos y maderas nobles que no se encuentran en otras épocas del año.
                    </p>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="border-l-4 border-green-600 pl-4">
                            <h4 class="font-bold text-gray-800">100% Orgánico</h4>
                            <p class="text-sm text-gray-500">Sin pesticidas químicos.</p>
                        </div>
                        <div class="border-l-4 border-green-600 pl-4">
                            <h4 class="font-bold text-gray-800">Comercio Justo</h4>
                            <p class="text-sm text-gray-500">Apoyo directo al productor.</p>
                        </div>
                    </div>
                    <div class="pt-6">
                        <a href="/calculadora" class="bg-green-700 text-white px-8 py-4 rounded-xl font-bold hover:bg-green-800 transition-colors shadow-lg inline-block">
                            Cotizar Envío de Temporada
                        </a>
                    </div>
                </div>
                <div class="bg-white p-4 rounded-3xl shadow-2xl rotate-3">
                    <img 
                        src="https://nics.bg/images/cocoa_big.jpg" 
                        class="rounded-2xl w-full h-full object-cover"
                        alt="Granos de cacao"
                    />
                </div>
            </div>
        </section>

        <section class="bg-green-900 py-16 text-white text-center">
            <div class="max-w-4xl mx-auto px-4">
                <h2 class="text-3xl font-bold mb-8">Especificaciones del Lote</h2>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
                    <div>
                        <p class="text-green-400 text-sm uppercase">Humedad</p>
                        <p class="text-2xl font-bold">7.0% Max</p>
                    </div>
                    <div>
                        <p class="text-green-400 text-sm uppercase">Fermentación</p>
                        <p class="text-2xl font-bold">85% - 90%</p>
                    </div>
                    <div>
                        <p class="text-green-400 text-sm uppercase">Tipo</p>
                        <p class="text-2xl font-bold">Trinitario</p>
                    </div>
                    <div>
                        <p class="text-green-400 text-sm uppercase">Cosecha</p>
                        <p class="text-2xl font-bold">Feb 2026</p>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    main {
        font-family: 'Inter', sans-serif;
    }
</style>
---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/home/Hero.astro";
import CategoryHome from "../components/home/CategoryHome.astro";
import FeaturedProducts from "../components/home/FeaturedProducts.astro";

---

<Layout>
    <Hero />
    
    <section class="max-w-7xl mx-auto px-4 py-8">
        <div class="bg-primary/5 border-2 border-dashed border-primary/20 rounded-2xl p-8 flex flex-col md:flex-row items-center justify-between gap-6">
            <div>
                <h2 class="text-2xl font-bold text-primary">¿Quieres saber cuánto cuesta tu envío?</h2>
                <p class="text-gray-600">Calcula al instante el costo de exportación según el peso y destino.</p>
            </div>
            <a 
                href="calculadora" 
                class="bg-primary text-white px-8 py-4 rounded-xl font-bold hover:scale-105 transition-transform shadow-lg whitespace-nowrap"
            >
                Abrir Calculadora de Envío
            </a>
        </div>
    </section>

    <CategoryHome />
    <FeaturedProducts />
</Layout>
